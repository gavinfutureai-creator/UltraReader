# UltraReader 配置文件示例
# 复制此文件为 .env 或 configs/default.yaml 进行配置

# LLM 配置
# 主模型（Minimax）
ULTRAREADER_LLM_MODEL=minimax-2.7
ULTRAREADER_LLM_BASE_URL=https://api.minimaxi.com/anthropic
ANTHROPIC_API_KEY=your-api-key-here

# 备用模型（Ollama）
# ULTRAREADER_LLM_MODEL=qwen3.5:9b
# ULTRAREADER_LLM_BASE_URL=http://localhost:11434

# 输出配置
ULTRAREADER_OUTPUT_DIR=output
