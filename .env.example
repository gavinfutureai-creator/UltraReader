# UltraReader 配置文件示例
# 复制此文件为 .env 进行配置

# ==================== LLM 配置 ====================

# 首选模型: minimax (MiniMax-M2.7)
# 备用模型: ollama (当 minimax 不可用时自动切换)
ULTRAREADER_LLM_PROVIDER=minimax
ULTRAREADER_LLM_MODEL=MiniMax-M2.7
ULTRAREADER_LLM_BASE_URL=https://api.minimaxi.com/anthropic

# Minimax API Key
ANTHROPIC_API_KEY=your-api-key-here

# ==================== 备用模型配置 ====================
# 当 minimax 不可用时，自动切换到 ollama
# ULTRAREADER_LLM_MODEL=qwen3.5:9b
# ULTRAREADER_LLM_BASE_URL=http://localhost:11434

# ==================== 输出配置 ====================
ULTRAREADER_OUTPUT_DIR=output
